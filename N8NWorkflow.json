    {
      "parameters": {
        "jsCode": "// Hole die Webhook-Daten\nconst body = $input.first().json.body || $input.first().json;\nconst config = body.config || {};\n\n// Plattformen verarbeiten\nlet plattformen = [];\nif (config.platforms) {\n  if (config.platforms.facebook) plattformen.push('Facebook');\n  if (config.platforms.instagram) plattformen.push('Instagram');\n  if (config.platforms.linkedin) plattformen.push('LinkedIn');\n  if (config.platforms.twitter) plattformen.push('Twitter');\n}\nif (plattformen.length === 0) plattformen = ['Facebook', 'Instagram'];\n\n// Plattformen als Text\nconst plattformen_text = plattformen.length === 1 \n  ? plattformen[0] \n  : plattformen.slice(0, -1).join(', ') + ' und ' + plattformen[plattformen.length - 1];\n\n// Tonalität mapping\nconst tonalityMap = {\n  'professional': 'professionell',\n  'casual': 'locker und freundlich',\n  'humorous': 'humorvoll',\n  'inspiring': 'inspirierend'\n};\n\n// Zielgruppe mapping\nconst audienceMap = {\n  'b2b': 'B2B Geschäftskunden',\n  'b2c': 'B2C Endverbraucher',\n  'both': 'B2B und B2C'\n};\n\n// Emoji-Hinweis\nconst emojiMap = {\n  'none': 'Keine Emojis verwenden',\n  'minimal': 'Wenige Emojis (1-2)',\n  'moderate': 'Moderate Emoji-Nutzung (3-5)',\n  'heavy': 'Viele Emojis verwenden'\n};\n\n// Hashtags als String\nconst hashtagString = Array.isArray(config.hashtags) \n  ? config.hashtags.join(' ') \n  : (config.hashtags || '#business #success');\n\n// Sprache\nconst languageMap = {\n  'de': 'Deutsch',\n  'en': 'Englisch'\n};\n\n// Image Prompt erstellen\nconst imagePrompt = `Generiere ein Bild für einen Social Media Post. Thema: ${config.topic || 'Business & Erfolg'}. Stil: ${tonalityMap[config.tonality] || 'professionell'}, modern, ansprechend. Zielgruppe: ${audienceMap[config.targetAudience] || 'Allgemeine Zielgruppe'}. Das Bild soll für ${plattformen_text} optimiert sein. Kein Text im Bild.`;\n\n// Rückgabe der formatierten Daten\nreturn {\n  json: {\n    thema: config.topic || 'Business & Erfolg',\n    zielgruppe: audienceMap[config.targetAudience] || 'Allgemeine Zielgruppe',\n    tonalitaet: tonalityMap[config.tonality] || 'professionell',\n    plattformen: plattformen,\n    plattformen_text: plattformen_text,\n    hinweise: `Sprache: ${languageMap[config.language] || 'Deutsch'}. ${emojiMap[config.emojiUsage] || ''}. Hashtags: ${hashtagString}`,\n    hashtags: hashtagString,\n    language: config.language || 'de',\n    emojiUsage: config.emojiUsage || 'moderate',\n    timestamp: new Date().toISOString(),\n    imagePrompt: imagePrompt\n  }\n};"
      },
