      "name": "Langdock Response Parser1"
    },
    {
      "parameters": {
        "jsCode": "// Bild Response Parser - für Langdock Format\nconst langdockResponse = $input.first().json;\n\nlet imageData = '';\nlet isBase64 = false;\n\n// Langdock Format: result[].content[].output.value.images[].base64\nif (langdockResponse.result && Array.isArray(langdockResponse.result)) {\n  for (const entry of langdockResponse.result) {\n    if (entry.role === 'tool' && entry.content && Array.isArray(entry.content)) {\n      for (const contentItem of entry.content) {\n        if (contentItem.type === 'tool-result' && contentItem.output) {\n          const output = contentItem.output;\n          \n          // Prüfe output.value.images[]\n          if (output.value && output.value.images && Array.isArray(output.value.images)) {\n            for (const img of output.value.images) {\n              if (img.base64) {\n                // Base64-String gefunden\n                const base64String = img.base64;\n                if (base64String.startsWith('data:image')) {\n                  imageData = base64String;\n                } else {\n                  imageData = 'data:image/png;base64,' + base64String;\n                }\n                isBase64 = true;\n                break;\n              } else if (img.url && img.url !== 'N/A') {\n                imageData = img.url;\n                isBase64 = false;\n                break;\n              }\n            }\n          }\n          \n          if (imageData) break;\n        }\n      }\n    }\n    if (imageData) break;\n  }\n}\n\nreturn {\n  json: {\n    imageUrl: isBase64 ? '' : imageData,\n    imageData: isBase64 ? imageData : '',\n    isBase64: isBase64,\n    hasImage: imageData !== ''\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -9712,
        1632
      ],
      "id": "b17a63d8-4802-4ad2-a4f3-9e0e9c2a3bdb",
      "name": "Bild Response Parser1"
    },
    {
      "parameters": {
        "jsCode": "// Base64 Bild für Supabase Upload vorbereiten\nconst imageData = $input.first().json.imageData || '';\nconst hasImage = $input.first().json.hasImage || false;\nconst imageUrl = $input.first().json.imageUrl || '';\n\n// Wenn kein Bild vorhanden\nif (!hasImage) {\n  return {\n    json: {\n      skipUpload: true,\n      imageUrl: '',\n      fileName: '',\n      hasImage: false\n    }\n  };\n}\n\n// Wenn bereits eine URL (kein Base64)\nif (imageUrl && !$input.first().json.isBase64) {\n  return {\n    json: {\n      skipUpload: true,\n      imageUrl: imageUrl,\n      fileName: '',\n      hasImage: true\n    }\n  };\n}\n\nif (!imageData) {\n  return {\n    json: {\n      skipUpload: true,\n      imageUrl: '',\n      fileName: '',\n      hasImage: false\n    }\n  };\n}\n\nconst timestamp = new Date().getTime();\nconst fileName = `post_${timestamp}.png`;\n\n// Base64 String extrahieren (ohne data:image/png;base64, prefix)\nlet base64Clean = imageData;\nif (imageData.includes(',')) {\n  base64Clean = imageData.split(',')[1];\n}\n\nreturn {\n  json: {\n    fileName: fileName,\n    contentType: 'image/png',\n    timestamp: timestamp,\n    skipUpload: false\n  },\n  binary: {\n    data: {\n      data: base64Clean,\n      mimeType: 'image/png',\n      fileName: fileName\n    }\n  }\n};"
      },
