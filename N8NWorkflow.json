        "jsCode": "const credentials = $('🔑 Credentials').first().json;\nconst responseData = $input.first().json;\n\nlet posts = [];\nif (Array.isArray(responseData)) {\n  posts = responseData;\n} else {\n  posts = $input.all().map(i => i.json);\n}\n\nconst postsWithIds = posts.filter(\n  p => (p.fb_post_id && p.fb_post_id !== null && p.fb_post_id !== '') || \n       (p.ig_post_id && p.ig_post_id !== null && p.ig_post_id !== '')\n);\n\nif (postsWithIds.length === 0) {\n  return { json: { skip: true, message: 'Keine Posts mit Post-IDs gefunden' } };\n}\n\nreturn postsWithIds.map(p => {\n  let fbId = p.fb_post_id || '';\n  if (fbId && !fbId.includes('_')) {\n    fbId = credentials.fbPageId + '_' + fbId;\n  }\n  return {\n    json: {\n      id: p.id,\n      fb_post_id: fbId,\n      ig_post_id: p.ig_post_id || '',\n      platform: p.platform,\n      fbAccessToken: credentials.fbAccessToken,\n      supabaseUrl: credentials.supabaseUrl,\n      supabaseKey: credentials.supabaseKey\n    }\n  };\n});"
      },
