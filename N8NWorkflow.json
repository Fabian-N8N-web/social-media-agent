      "parameters": {
        "jsCode": "// Langdock Response parsen\nconst langdockResponse = $input.first().json;\n\n// Content aus Langdock extrahieren\nlet generatedContent = '';\n\nif (langdockResponse.result && langdockResponse.result[0]) {\n  generatedContent = langdockResponse.result[0].content || '';\n} else if (langdockResponse.choices && langdockResponse.choices[0]) {\n  generatedContent = langdockResponse.choices[0].message?.content || '';\n} else if (langdockResponse.content) {\n  generatedContent = langdockResponse.content;\n}\n\nreturn {\n  json: {\n    content: generatedContent\n  }\n};"
      },
